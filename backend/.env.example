# Copy this to .env and fill in your values

# Server
PORT=8000
# Dev: keep localhost origins. Production: set to your real domain only.
# e.g. ALLOWED_ORIGINS=https://jeetratanpara.dev,https://admin.jeetratanpara.dev
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:5173

# Admin Auth — MUST change before deploying!
# Generate a strong key: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-in-production-please
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme
# Token expires after this many hours (default 24)
TOKEN_EXPIRE_HOURS=24

# SMTP (optional — for real email delivery via contact form)
# Gmail setup:
#   1. Enable 2FA on your Google account
#   2. Generate an App Password: myaccount.google.com/apppasswords
#   3. Use that App Password as SMTP_PASS (NOT your normal Gmail password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SSL=false
SMTP_USER=you@gmail.com
SMTP_PASS=your_16_char_app_password
SMTP_TO=you@gmail.com
